#!/bin/bash

APP_NAME="ClashApp"

# Clean up old "sparkle" installation
if [ -L '/usr/bin/sparkle' ]; then
    if type update-alternatives 2>/dev/null >&1; then
        update-alternatives --remove 'sparkle' '/opt/sparkle/sparkle' 2>/dev/null || true
    fi
    rm -f '/usr/bin/sparkle'
fi

if type update-alternatives 2>/dev/null >&1; then
    # Remove previous link if it doesn't use update-alternatives
    if [ -L "/usr/bin/${APP_NAME}" -a -e "/usr/bin/${APP_NAME}" -a "$(readlink "/usr/bin/${APP_NAME}")" != "/etc/alternatives/${APP_NAME}" ]; then
        rm -f "/usr/bin/${APP_NAME}"
    fi
    update-alternatives --install "/usr/bin/${APP_NAME}" "${APP_NAME}" "/opt/${APP_NAME}/${APP_NAME}" 100 || ln -sf "/opt/${APP_NAME}/${APP_NAME}" "/usr/bin/${APP_NAME}"
else
    ln -sf "/opt/${APP_NAME}/${APP_NAME}" "/usr/bin/${APP_NAME}"
fi

chmod 4755 "/opt/${APP_NAME}/chrome-sandbox" || true
chmod +sx "/opt/${APP_NAME}/resources/sidecar/mihomo"
chmod +sx "/opt/${APP_NAME}/resources/sidecar/mihomo-alpha"

if hash update-mime-database 2>/dev/null; then
    update-mime-database /usr/share/mime || true
fi

if hash update-desktop-database 2>/dev/null; then
    update-desktop-database /usr/share/applications || true
fi
