#!/bin/sh

APP_NAME="ClashApp"
CORRECT_PATH="/Applications/${APP_NAME}.app"
WRONG_PATH="/Applications/${APP_NAME}.localized/${APP_NAME}.app"

# --- Fix install path if installer created .localized directory ---
if [ -d "$WRONG_PATH" ] && [ ! -d "$CORRECT_PATH" ]; then
    mv "$WRONG_PATH" "$CORRECT_PATH"
    rm -rf "/Applications/${APP_NAME}.localized"
fi

# --- Set suid on mihomo binaries ---
chown root:admin "$CORRECT_PATH/Contents/Resources/sidecar/mihomo"
chown root:admin "$CORRECT_PATH/Contents/Resources/sidecar/mihomo-alpha"
chmod +s "$CORRECT_PATH/Contents/Resources/sidecar/mihomo"
chmod +s "$CORRECT_PATH/Contents/Resources/sidecar/mihomo-alpha"

exit 0
